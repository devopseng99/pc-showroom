{
  "name": "pc-showroom",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pc-showroom/server dev",
    "dev:ui": "pnpm --filter @pc-showroom/ui dev",
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @pc-showroom/ui build",
    "build:server": "pnpm --filter @pc-showroom/server build",
    "db:generate": "pnpm --filter @pc-showroom/server db:generate",
    "db:migrate": "pnpm --filter @pc-showroom/server db:migrate",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
